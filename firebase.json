{
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "headers": [
      {
        "source": "**/*.{css,js}",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/favicon.ico", "destination": "/brand/general-profile-picture.png" }
    ],
    "redirects": [
      { "source": "/favicon.ico", "destination": "/brand/general-profile-picture.png", "type": 308 },
      { "source": "/sitemap.xml", "destination": "https://tucredito-ai.ramirezquezadajoe.workers.dev/sitemap.xml", "type": 308 }
    ]
  },
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
